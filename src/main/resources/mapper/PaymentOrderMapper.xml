<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ming.hospital.dao.PaymentOrderMapper">

    <resultMap id="BaseResultMap" type="com.ming.hospital.pojo.PaymentOrder">
        <id column="order_id" property="orderId"/>
        <result column="aid" property="aid"/>
        <result column="uid" property="uid"/>
        <result column="order_no" property="orderNo"/>
        <result column="amount" property="amount"/>
        <result column="pay_type" property="payType"/>
        <result column="pay_status" property="payStatus"/>
        <result column="pay_time" property="payTime"/>
        <result column="createtime" property="createtime"/>
        <result column="updatetime" property="updatetime"/>
    </resultMap>

    <insert id="insert" parameterType="com.ming.hospital.pojo.PaymentOrder">
        INSERT INTO payment_order (order_id, aid, uid, order_no, amount, pay_type, pay_status, createtime, updatetime)
        VALUES (#{orderId}, #{aid}, #{uid}, #{orderNo}, #{amount}, #{payType}, #{payStatus}, #{createtime}, #{updatetime})
    </insert>

    <update id="updatePayStatus">
        UPDATE payment_order SET pay_status = #{payStatus}, pay_time = NOW(), updatetime = NOW() 
        WHERE order_id = #{orderId}
    </update>

    <select id="selectByPrimaryKey" resultMap="BaseResultMap">
        SELECT * FROM payment_order WHERE order_id = #{orderId}
    </select>

    <select id="selectByOrderNo" resultMap="BaseResultMap">
        SELECT * FROM payment_order WHERE order_no = #{orderNo}
    </select>

    <select id="selectByAppointmentId" resultMap="BaseResultMap">
        SELECT * FROM payment_order WHERE aid = #{aid}
    </select>

</mapper>
